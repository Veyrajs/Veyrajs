{
  "name": "@veyrajs/core",
  "version": "0.1.0",
  "description": "Framework-agnostic 2D canvas engine: scene graph, renderer abstraction, camera, events, hit-testing, transforms, controls, serialization, and plugin system.",
  "license": "MIT",
  "author": "Veyrajs",
  "homepage": "https://github.com/Veyrajs/Veyrajs/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veyrajs/Veyrajs.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/Veyrajs/Veyrajs/issues",
  "keywords": [
    "canvas",
    "2d",
    "scene-graph",
    "graphics",
    "renderer",
    "typescript",
    "konva",
    "fabric"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "happy-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
