{
  "name": "@veyrajs/vue",
  "version": "0.1.2",
  "description": "Vue 3 adapter for Veyrajs — declarative components + composables over the engine.",
  "license": "MIT",
  "author": "Veyrajs",
  "homepage": "https://veyrajs.github.io/Veyrajs/adapters/vue/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veyrajs/Veyrajs.git",
    "directory": "packages/vue"
  },
  "bugs": "https://github.com/Veyrajs/Veyrajs/issues",
  "keywords": ["canvas", "2d", "scene-graph", "vue", "vue3", "graphics", "typescript"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@veyrajs/core": "workspace:*"
  },
  "devDependencies": {
    "@vue/test-utils": "catalog:",
    "happy-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  }
}
