{
  "name": "@veyrajs/react",
  "version": "0.1.1",
  "description": "React adapter for Veyrajs — declarative components + hooks over the engine.",
  "license": "MIT",
  "author": "Veyrajs",
  "homepage": "https://github.com/Veyrajs/Veyrajs/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veyrajs/Veyrajs.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/Veyrajs/Veyrajs/issues",
  "keywords": ["canvas", "2d", "scene-graph", "react", "graphics", "typescript"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@veyrajs/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "happy-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
