{
  "name": "@veyrajs/svelte",
  "version": "0.1.0",
  "description": "Svelte 5 adapter for Veyrajs — declarative components over the engine.",
  "license": "MIT",
  "author": "Veyrajs",
  "homepage": "https://github.com/Veyrajs/Veyrajs/tree/main/packages/svelte#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veyrajs/Veyrajs.git",
    "directory": "packages/svelte"
  },
  "bugs": "https://github.com/Veyrajs/Veyrajs/issues",
  "keywords": ["canvas", "2d", "scene-graph", "svelte", "svelte5", "graphics", "typescript"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": ["**/*.svelte"],
  "files": ["dist"],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "svelte-package --input src",
    "dev": "svelte-package --input src --watch",
    "test": "vitest run",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@veyrajs/core": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/package": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/svelte": "catalog:",
    "happy-dom": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
