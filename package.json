{
  "name": "annotacanvas-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AnnotaCanvas — framework-agnostic 2D canvas engine (monorepo root).",
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "dev": "pnpm --filter @annotacanvas/demo dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "clean": "pnpm -r exec rm -rf dist coverage .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
